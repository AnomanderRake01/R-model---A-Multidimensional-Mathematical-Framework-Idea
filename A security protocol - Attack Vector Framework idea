    hw_data = "CPU_ID_789456-MEM_LATENCY_0.0023ms" 
    return hashlib.sha256(hw_data.encode()).hexdigest()

def generate_epoch_seed(previous_tension, hardware_anchor):
    # This 'seals' the tension into the hardware identity
    combined = f"{previous_tension}{hardware_anchor}{os.urandom(16)}"
    return hashlib.sha256(combined.encode()).hexdigest()

