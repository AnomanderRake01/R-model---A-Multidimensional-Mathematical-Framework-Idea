## 5. Verification Code (Python)
```python
import time

def run_r_model(limit=1000000):
    cache = {1: (0, 0, 0)}
    global_odd, global_even = 0, 0
    max_steps, max_int = 0, 0
    start_time = time.time()

    for i in range(1, limit + 1):
        n, temp_path = i, []
        while n not in cache:
            temp_path.append(n)
            n = (n // 2) if n % 2 == 0 else (3 * n + 1)

        cached_steps, cached_even, cached_odd = cache[n]
        for val in reversed(temp_path):
            is_even = 1 if val % 2 == 0 else 0
            cached_steps += 1
            cached_even += is_even
            cached_odd += (1 - is_even)
            if val <= limit * 2:
                cache[val] = (cached_steps, cached_even, cached_odd)

        global_even += cached_even
        global_odd += cached_odd
        if cached_steps > max_steps:
            max_steps, max_int = cached_steps, i

    r_ratio = global_even / global_odd
    print(f"Range: 1 to {limit:,} | R-Ratio: {r_ratio:.4f} | Runtime: {time.time()-start_time:.2f}s")

run_r_model(1000000)
